<script>
  // ══════════════════════════════════════════════════════
  //  HIGH-FREQUENCY MOUSE TESTER
  //  Architecture: event queue → rAF drain → canvas paint
  //  This decouples event capture from rendering entirely.
  //  At 8000Hz = 1 event per 0.125ms. The browser fires
  //  mousemove at up to ~1000Hz max on most systems, but
  //  we measure the raw DOMHighResTimeStamp accurately.
  // ══════════════════════════════════════════════════════

  const zone      = document.getElementById('zone');
  const heatCvs   = document.getElementById('heatmap');
  const hCtx      = heatCvs.getContext('2d');
  const cursorDot = document.getElementById('cursor-dot');
  const prompt    = document.getElementById('prompt');
  const pollCvs   = document.getElementById('poll-chart');
  const pCtx      = pollCvs.getContext('2d');

  // Stat elements
  const els = {
    polling:  document.getElementById('s-polling'),
    peak:     document.getElementById('s-peak'),
    response: document.getElementById('s-response'),
    cps:      document.getElementById('s-cps'),
    speed:    document.getElementById('s-speed'),
    cLeft:    document.getElementById('c-left'),
    cRight:   document.getElementById('c-right'),
    cMiddle:  document.getElementById('c-middle'),
    cTotal:   document.getElementById('c-total'),
    cHeat:    document.getElementById('c-heat'),
    minpoll:  document.getElementById('m-minpoll'),
    maxpoll:  document.getElementById('m-maxpoll'),
    jitter:   document.getElementById('m-jitter'),
    maxspeed: document.getElementById('m-maxspeed'),
    cdur:     document.getElementById('m-cdur'),
    events:   document.getElementById('m-events'),
  };

  // State
  let st = {
    lc:0, rc:0, mc:0, heat:0,
    lastT:null, lastPos:null,
    maxSpd:0, minPI:Infinity, maxPI:0,
    downT:null, cpsArr:[],
    pollHistory:[], // circular buffer, max 120
    intervals:[],   // for jitter calc
    totalEvents:0,
    peakHz:0,
    pendingCursor:null, // {x,y} — latest unrendered position
    rafId:null,
    domUpdatesNeeded:false,
    // DOM update throttle — update text at 30fps max
    lastDomUpdate:0,
  };

  function resetState() {
    st = {
      lc:0, rc:0, mc:0, heat:0,
      lastT:null, lastPos:null,
      maxSpd:0, minPI:Infinity, maxPI:0,
      downT:null, cpsArr:[],
      pollHistory:[], intervals:[],
      totalEvents:0, peakHz:0,
      pendingCursor:null, rafId:null,
      domUpdatesNeeded:false, lastDomUpdate:0,
    };
  }

  // Resize heatmap canvas
  function resizeCanvases() {
    const r = zone.getBoundingClientRect();
    heatCvs.width  = r.width;  heatCvs.height  = r.height;
    pollCvs.width  = pollCvs.offsetWidth; // use CSS width
    drawPollChart();
  }
  resizeCanvases();
  window.addEventListener('resize', resizeCanvases, { passive:true });

  // ── MOUSEMOVE: capture only, no DOM writes here ──
  zone.addEventListener('mousemove', e => {
    const r   = zone.getBoundingClientRect();
    const x   = e.clientX - r.left;
    const y   = e.clientY - r.top;
    const now = e.timeStamp; // DOMHighResTimeStamp — most accurate

    st.pendingCursor = {x, y};
    prompt.style.display = 'none';

    if (st.lastT !== null) {
      const dt = now - st.lastT;
      if (dt > 0 && dt < 100) { // ignore huge gaps (mouse left zone)
        const hz = 1000 / dt;
        st.pollHistory.push(hz);
        if (st.pollHistory.length > 120) st.pollHistory.shift();
        st.intervals.push(dt);
        if (st.intervals.length > 120) st.intervals.shift();

        if (dt < st.minPI) st.minPI = dt;
        if (dt > st.maxPI) st.maxPI = dt;
        if (hz > st.peakHz) st.peakHz = hz;

        if (st.lastPos) {
          const dx = x - st.lastPos.x, dy = y - st.lastPos.y;
          const spd = Math.sqrt(dx*dx + dy*dy) / (dt / 1000);
          if (spd > st.maxSpd) st.maxSpd = spd;
          // store last speed for display
          st._lastSpd = spd;
          st._lastDt  = dt;
          st._lastHz  = hz;
        }
      }
    }

    st.lastT   = now;
    st.lastPos = {x, y};
    st.totalEvents++;
    st.domUpdatesNeeded = true;

    // Draw heatmap dot directly (canvas, not DOM)
    const g = hCtx.createRadialGradient(x, y, 0, x, y, 22);
    g.addColorStop(0, 'rgba(124,58,237,0.12)');
    g.addColorStop(1, 'rgba(124,58,237,0)');
    hCtx.beginPath();
    hCtx.arc(x, y, 22, 0, Math.PI * 2);
    hCtx.fillStyle = g;
    hCtx.fill();
    st.heat++;

  }, { passive: true });

  // ── rAF LOOP: render cursor + update DOM at 60fps ──
  function rafLoop(ts) {
    st.rafId = requestAnimationFrame(rafLoop);

    // Move cursor dot using transform (GPU-composited, zero layout cost)
    if (st.pendingCursor) {
      const {x, y} = st.pendingCursor;
      cursorDot.style.display = 'block';
      cursorDot.style.transform = `translate(calc(${x}px - 50%), calc(${y}px - 50%))`;
      st.pendingCursor = null;
    }

    // DOM text updates throttled to ~30fps (every 33ms)
    if (st.domUpdatesNeeded && ts - st.lastDomUpdate > 33) {
      st.lastDomUpdate = ts;
      st.domUpdatesNeeded = false;

      const avg = st.pollHistory.length
        ? st.pollHistory.reduce((a,b)=>a+b,0) / st.pollHistory.length
        : 0;

      els.polling.textContent  = avg.toFixed(0);
      els.peak.textContent     = st.peakHz.toFixed(0);
      els.response.textContent = (st._lastDt || 0).toFixed(2);
      els.speed.textContent    = (st._lastSpd || 0).toFixed(0);
      els.cHeat.textContent    = st.heat;
      els.events.textContent   = st.totalEvents;

      // Jitter = standard deviation of intervals
      if (st.intervals.length > 2) {
        const mean = st.intervals.reduce((a,b)=>a+b,0) / st.intervals.length;
        const variance = st.intervals.reduce((a,b)=>a+(b-mean)**2,0) / st.intervals.length;
        els.jitter.textContent = Math.sqrt(variance).toFixed(3) + ' ms';
      }

      if (st.minPI < Infinity) els.minpoll.textContent = st.minPI.toFixed(3) + ' ms';
      if (st.maxPI > 0)        els.maxpoll.textContent = st.maxPI.toFixed(2) + ' ms';
      els.maxspeed.textContent = st.maxSpd.toFixed(0) + ' px/s';

      // High-freq badge
      if (avg > 1500) {
        document.getElementById('hf-badge').classList.add('show');
      }

      drawPollChart();
    }
  }
  st.rafId = requestAnimationFrame(rafLoop);

  // ── POLL CHART ──
  function drawPollChart() {
    const w = pollCvs.width, h = pollCvs.height;
    pCtx.clearRect(0, 0, w, h);
    if (st.pollHistory.length < 2) return;

    const max = Math.max(...st.pollHistory, 1200);
    const pts = st.pollHistory;
    const step = w / (pts.length - 1);

    // Fill
    pCtx.beginPath();
    pCtx.moveTo(0, h);
    pts.forEach((v, i) => {
      pCtx.lineTo(i * step, h - (v / max) * (h - 4));
    });
    pCtx.lineTo((pts.length-1)*step, h);
    pCtx.closePath();
    const grad = pCtx.createLinearGradient(0, 0, 0, h);
    grad.addColorStop(0, 'rgba(124,58,237,0.35)');
    grad.addColorStop(1, 'rgba(124,58,237,0.02)');
    pCtx.fillStyle = grad;
    pCtx.fill();

    // Line
    pCtx.beginPath();
    pts.forEach((v, i) => {
      const px = i * step, py = h - (v / max) * (h - 4);
      i === 0 ? pCtx.moveTo(px, py) : pCtx.lineTo(px, py);
    });
    pCtx.strokeStyle = '#a78bfa';
    pCtx.lineWidth = 1.5;
    pCtx.stroke();
  }

  // ── CLICK EVENTS ──
  zone.addEventListener('mousedown', e => {
    e.preventDefault();
    st.downT = e.timeStamp;

    if (e.button === 0) { st.lc++; els.cLeft.textContent  = st.lc; }
    else if (e.button === 2) { st.rc++; els.cRight.textContent = st.rc; }
    else if (e.button === 1) { st.mc++; els.cMiddle.textContent = st.mc; }
    const total = st.lc + st.rc + st.mc;
    els.cTotal.textContent = total;

    // CPS
    const now = e.timeStamp;
    st.cpsArr = st.cpsArr.filter(t => now - t < 1000);
    st.cpsArr.push(now);
    els.cps.textContent = st.cpsArr.length;

    // Ripple
    const r = zone.getBoundingClientRect();
    const rip = document.createElement('div');
    rip.className = 'click-ripple';
    rip.style.left = (e.clientX - r.left) + 'px';
    rip.style.top  = (e.clientY - r.top)  + 'px';
    zone.appendChild(rip);
    setTimeout(() => rip.remove(), 450);
  });

  zone.addEventListener('mouseup', e => {
    if (st.downT) {
      els.cdur.textContent = (e.timeStamp - st.downT).toFixed(1) + ' ms';
      st.downT = null;
    }
  });

  zone.addEventListener('contextmenu', e => e.preventDefault());

  // ── RESET ──
