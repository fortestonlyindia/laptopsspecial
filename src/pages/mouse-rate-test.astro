  .cta-text strong { color:var(--text); }
  .cta-btn {
    background:#a78bfa; color:#fff;
    font-family:var(--font-display); font-size:.85rem; font-weight:700;
    padding:.6rem 1.25rem; border-radius:8px; text-decoration:none; transition:opacity .15s;
  }
