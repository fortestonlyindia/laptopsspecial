        maxInterval:     st.maxPI > 0 ? st.maxPI.toFixed(2) + ' ms' : 'N/A',
        jitter:          jitter !== 'N/A' ? jitter + ' ms' : 'N/A',
        maxMovementSpeed: st.maxSpd.toFixed(0) + ' px/s',
        leftClicks:  st.lc,
        rightClicks: st.rc,
