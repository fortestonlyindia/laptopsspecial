    font-family:var(--font-display); font-size:.75rem; font-weight:600;
    padding:.35rem .85rem; border-radius:6px; cursor:pointer; transition:all .15s;
  }
  .btn-sm:hover { border-color:var(--muted); color:var(--text); }
  .btn-export { border-color:rgba(124,58,237,.4); color:#a78bfa; }
  [data-theme="light"] .btn-export { color:#7c3aed; border-color:rgba(124,58,237,.5); }
  .btn-export:hover { border-color:#a78bfa; background:rgba(124,58,237,.08); color:#a78bfa; }
  .btn-csv { border-color:rgba(34,197,94,.3); color:#22c55e; }
  .btn-csv:hover { border-color:#22c55e; background:rgba(34,197,94,.08); color:#22c55e; }

  /* TRACKING ZONE */
  .tracking-zone {
    position:relative; height:300px;
    background:#0a1020; cursor:crosshair; overflow:hidden;
    /* Use transform for compositing — no main thread repaints */
    transform:translateZ(0);
    will-change:transform;
  }
  [data-theme="light"] .tracking-zone { background:#e8edf5; }
  .tracking-zone canvas { position:absolute; inset:0; pointer-events:none; }
  .tracking-prompt {
    position:absolute; inset:0;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    gap:.5rem; pointer-events:none;
  }
  .tracking-prompt-icon { font-size:2.5rem; opacity:.35; filter: grayscale(0); }
  .tracking-prompt-text { color:var(--text2); font-size:.9rem; font-weight:600; }
  /* GPU-composited cursor dot — transform-based, no layout */
  .cursor-dot {
    position:absolute; width:10px; height:10px; border-radius:50%;
    background:#a78bfa; border:2px solid rgba(255,255,255,.7);
    top:0; left:0;
    transform:translate(-50%,-50%);
    pointer-events:none; display:none;
    box-shadow:0 0 10px rgba(124,58,237,.5);
    /* GPU layer — critical for 8000Hz */
    will-change:transform;
    transition:none !important;
  }
  .click-ripple {
    position:absolute; width:18px; height:18px; border-radius:50%;
    border:2px solid #a78bfa; top:0; left:0;
    transform:translate(-50%,-50%) scale(0);
    pointer-events:none;
    animation:ripple .45s ease-out forwards;
  }
  @keyframes ripple { to { transform:translate(-50%,-50%) scale(3.5); opacity:0; } }

  /* CLICK COUNTERS */
  .click-section {
    padding:1rem 1.5rem; border-top:1px solid var(--border);
    display:flex; gap:.75rem; flex-wrap:wrap;
  }
  .click-counter {
    flex:1; min-width:90px; background:var(--bg3);
    border:1px solid var(--border); border-radius:10px;
    padding:.8rem; text-align:center;
  }
  .click-label { font-size:.65rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--muted); margin-bottom:.3rem; }
  .click-val { font-family:var(--font-mono); font-size:1.35rem; font-weight:700; color:var(--text); }

  /* ADVANCED METRICS */
  .metrics-section { padding:.9rem 1.5rem 1.25rem; }
  .metrics-toggle {
    font-size:.78rem; font-weight:600; color:var(--muted);
    cursor:pointer; display:flex; align-items:center; gap:.4rem;
    margin-bottom:.75rem; background:none; border:none;
    font-family:var(--font-display); padding:0; transition:color .15s;
  }
  .metrics-toggle:hover { color:var(--text2); }
  .metrics-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:.75rem; }
  .metric-item { background:var(--bg3); border:1px solid var(--border); border-radius:8px; padding:.75rem 1rem; }
  .metric-name { font-size:.65rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--muted); margin-bottom:.3rem; }
  .metric-val { font-family:var(--font-mono); font-size:.95rem; font-weight:700; color:#a78bfa; }
  [data-theme="light"] .metric-val { color:#7c3aed; }

  /* POLLING HISTORY CHART */
  .chart-section { padding:0 1.5rem 1.25rem; border-top:1px solid var(--border); }
  .chart-label { font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.1em; color:var(--muted); margin:.9rem 0 .6rem; }
  #poll-chart { width:100%; height:60px; display:block; }

  /* CTA */
  .cta-banner { max-width:1080px; margin:1.5rem auto; padding:0 1.5rem; }
