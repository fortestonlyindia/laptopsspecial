  .post-cat-badge { font-size:.65rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--accent); background:rgba(0,212,255,.1); border:1px solid rgba(0,212,255,.2); padding:.18rem .48rem; border-radius:4px; }
  .post-title { font-size:.95rem; font-weight:700; color:var(--text); line-height:1.4; margin-bottom:.55rem; }
