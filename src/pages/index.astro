  /* ═══════════════════════════════════
     ROW LAYOUT
  ═══════════════════════════════════ */
  .kb-section { display:flex; flex-direction:column; gap:4px; }
  .kb-row { display:flex; gap:4px; align-items:flex-end; }

  /* Function row sits above main section with small gap */
  .fn-row { margin-bottom:6px; }
  /* Small gap between F4/F5 and F8/F9 */
  .fn-gap { width:10px; flex-shrink:0; }

  /* ═══════════════════════════════════
     NUMPAD TALL KEYS  (2u tall)
  ═══════════════════════════════════ */
  .k-tall {
    height:80px; /* 2 keys + 1 gap = 38+4+38 */
    justify-content:center;
  }

  /* ═══════════════════════════════════
     NAV CLUSTER — special layout
  ═══════════════════════════════════ */
  .nav-top-row   { display:flex; gap:4px; }
  .nav-mid-row   { display:flex; gap:4px; margin-top:4px; }
  .nav-space     { height:38px; width:38px; visibility:hidden; } /* invisible spacer */

  /* Arrow cluster */
  .arrow-group { display:flex; flex-direction:column; gap:4px; margin-top:4px; }
  .arrow-top   { display:flex; justify-content:center; }
  .arrow-bot   { display:flex; gap:4px; }

  /* ═══════════════════════════════════
     KEY HISTORY
