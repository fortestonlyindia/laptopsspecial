<!-- CONTENT -->
<div class="content-section">
  <h2>What is Keyboard Latency?</h2>
  <p>Keyboard latency is the delay between pressing a key and the signal being registered by your system. For everyday typing it is imperceptible, but in competitive gaming even a few milliseconds can affect your performance.</p>
  <div class="info-grid">
    <div class="info-card"><div class="info-card-icon">⚡</div><div class="info-card-title">Scan Rate</div><div class="info-card-desc">How many times per second the keyboard's controller scans for key presses. Higher means faster detection.</div></div>
    <div class="info-card"><div class="info-card-icon">📡</div><div class="info-card-title">Polling Rate</div><div class="info-card-desc">How often the keyboard reports data to your PC. Standard is 1000Hz (1ms). Gaming keyboards reach 8000Hz.</div></div>
    <div class="info-card"><div class="info-card-icon">⏱</div><div class="info-card-title">Response Time</div><div class="info-card-desc">Total delay from key press to on-screen action — scan rate plus polling rate plus system latency combined.</div></div>
    <div class="info-card"><div class="info-card-icon">🔌</div><div class="info-card-title">Connection Type</div><div class="info-card-desc">Wired USB has the lowest latency. Modern 2.4GHz wireless nearly matches wired. Bluetooth adds 10–30ms extra.</div></div>
  </div>

  <h2 style="margin-top:2rem;">Frequently Asked Questions</h2>
  <div class="faq-list">
    <div class="faq-item"><div class="faq-q">What is average keyboard latency?</div><div class="faq-a">Most keyboards fall between 1ms and 15ms depending on switch type (mechanical vs membrane) and connection method.</div></div>
    <div class="faq-item"><div class="faq-q">Which keyboard has the lowest latency?</div><div class="faq-a">The Logitech G915 TKL achieves as low as 1.3ms in wired mode, placing it among the fastest available keyboards today.</div></div>
    <div class="faq-item"><div class="faq-q">How can I reduce keyboard latency on Windows?</div><div class="faq-a">Update keyboard drivers, disable Filter Keys in accessibility settings, use a wired USB 3.0 connection, and close unnecessary background applications.</div></div>
    <div class="faq-item"><div class="faq-q">Does polling rate affect keyboard latency?</div><div class="faq-a">Yes. At 125Hz polling rate latency is around 8ms. At 1000Hz it drops to roughly 1ms. Higher polling rate equals lower latency.</div></div>
  </div>
</div>

<!-- ════════════════════════
     JAVASCRIPT
════════════════════════ -->
<script>
  // Variables ko global script scope mein define kiya hai taaki
  // functions unko har jagah access kar sakein
  let shortestPress = Infinity;
  let totalKeys = 0;
  let historyCleared = false;
  let keyDownTimes = new Map();
  let pressedCodes = new Set();
  
  // Handlers ko reference mein store karenge taaki removeEventListener kaam kare
  let handleKeyDown;
  let handleKeyUp;
  let handleReset;

  function getKeyEl(code) {
    return document.querySelector(`.k[data-code="${code}"]`);
  }

  function initKeyboardTester() {
    const sShort   = document.getElementById('s-short');
    const sScan    = document.getElementById('s-scan');
    const sCount   = document.getElementById('s-count');
    const sUnique  = document.getElementById('s-unique');
    const feed     = document.getElementById('history-feed');
    const prompt   = document.getElementById('kb-prompt');
    const btnReset = document.getElementById('btn-reset');

    // Agar elements page par nahi hain (yani hum dusre page par hain), toh exit
    if (!sShort) return; 

    handleKeyDown = (e) => {
      // Browser ke zaroori shortcuts ko block nahi hone dena hai
      const isSystemKey = 
        (e.ctrlKey && ['a', 'c', 'v', 'x'].includes(e.key.toLowerCase())) || // Ctrl+A/C/V/X
        (e.ctrlKey && ['Home', 'End'].includes(e.key)) || // Ctrl+Home/End
        (e.key === 'F5') || // Page Refresh
        (e.ctrlKey && e.key.toLowerCase() === 'r'); // Ctrl+R

      if (!isSystemKey) {
        e.preventDefault(); // Baaki saari keys (space, arrows) ko default scroll karne se roko
      }

      const el = getKeyEl(e.code);
      if (el) el.classList.add('pressed');
      if (!keyDownTimes.has(e.code)) {
        keyDownTimes.set(e.code, performance.now());
      }
      if (prompt) prompt.style.display = 'none';
    };

    handleKeyUp = (e) => {
      const el = getKeyEl(e.code);
      if (el) el.classList.remove('pressed');

      const t = keyDownTimes.get(e.code);
      if (t === undefined) return;
      keyDownTimes.delete(e.code);

      const dur = performance.now() - t;

      if (!historyCleared) {
        if(feed) feed.innerHTML = '';
        historyCleared = true;
      }

      // History tag
      if (feed) {
        const tag = document.createElement('span');
        tag.className = 'hkey';
        tag.textContent = e.key === ' ' ? 'Space' : (e.key.length > 8 ? e.code.replace('Key','').replace('Digit','').replace('Numpad','Num') : e.key);
        tag.title = `${dur.toFixed(1)} ms`;
        feed.prepend(tag);
        while (feed.children.length > 36) feed.removeChild(feed.lastChild);
      }

      // Stats
      totalKeys++;
      if(sCount) sCount.textContent = totalKeys;

      pressedCodes.add(e.code);
      if(sUnique) sUnique.textContent = pressedCodes.size;

      if (dur < shortestPress) {
        shortestPress = dur;
        if(sShort) sShort.textContent = dur.toFixed(1);
        if(sScan) sScan.textContent  = (1000 / dur).toFixed(0);
      }
    };

    handleReset = () => {
      shortestPress = Infinity;
      totalKeys = 0;
      historyCleared = false;
      pressedCodes.clear();
      if(sShort) sShort.textContent  = '—';
      if(sScan) sScan.textContent    = '—';
      if(sCount) sCount.textContent  = '0';
      if(sUnique) sUnique.textContent = '0';
      if(feed) feed.innerHTML = '<span style="color:var(--muted);font-size:.78rem;">Keys will appear here…</span>';
      document.querySelectorAll('.k.pressed').forEach(k => k.classList.remove('pressed'));
      if (prompt) prompt.style.display = '';
    };

    // Attach Event Listeners
    document.addEventListener('keydown', handleKeyDown);
    document.addEventListener('keyup', handleKeyUp);
    if(btnReset) btnReset.addEventListener('click', handleReset);
  }

  function cleanupKeyboardTester() {
    // Ye function jab page switch hoga tab run hoga, taaki purane listeners hata sakein
    document.removeEventListener('keydown', handleKeyDown);
    document.removeEventListener('keyup', handleKeyUp);
    
    const btnReset = document.getElementById('btn-reset');
    if(btnReset && handleReset) btnReset.removeEventListener('click', handleReset);
    
    // Variables reset kar dein memory save karne ke liye
    shortestPress = Infinity;
    totalKeys = 0;
    keyDownTimes.clear();
    pressedCodes.clear();
  }

  // Astro Lifecycle hooks
  // 1. Jab bhi page load ho (first time ya View Transition se), setup chalayein
  document.addEventListener('astro:page-load', initKeyboardTester);

