════════════════════════ -->
    <script>
        const sShort = document.getElementById("s-short");
        const sScan = document.getElementById("s-scan");
        const sCount = document.getElementById("s-count");
        const sUnique = document.getElementById("s-unique");
        const feed = document.getElementById("history-feed");
        const prompt = document.getElementById("kb-prompt");
        const btnReset = document.getElementById("btn-reset");

        let shortestPress = Infinity;
        let totalKeys = 0;
        let historyCleared = false;
        const keyDownTimes = new Map();
        const pressedCodes = new Set();

        function getKeyEl(code) {
            return document.querySelector(`.k[data-code="${code}"]`);
        }

        document.addEventListener("keydown", (e) => {
            // Agar user Ctrl, Alt, ya Meta (Windows/Mac) key use kar raha hai, ya F1-F12 daba raha hai
            // toh usko block mat karo, browser apna kaam karega.
            if (
                !e.ctrlKey &&
                !e.metaKey &&
                !e.altKey &&
                !e.key.startsWith("F")
            ) {
                // Sirf in keys par scroll roko taaki test karte waqt page upar-niche jump na kare
                if (
                    [
                        "Space",
                        "ArrowUp",
                        "ArrowDown",
                        "ArrowLeft",
                        "ArrowRight",
                    ].includes(e.code)
                ) {
                    e.preventDefault();
                }
            }

            // Yahan se purana code shuru hota hai jo keys ko screen par highlight karta hai
            const el = getKeyEl(e.code);
            if (el) el.classList.add("pressed");

            if (!keyDownTimes.has(e.code)) {
                keyDownTimes.set(e.code, performance.now());
            }
            if (prompt) prompt.style.display = "none";
        });

        document.addEventListener("keyup", (e) => {
            const el = getKeyEl(e.code);
            if (el) el.classList.remove("pressed");

            const t = keyDownTimes.get(e.code);
            if (t === undefined) return;
            keyDownTimes.delete(e.code);

            const dur = performance.now() - t;

            if (!historyCleared) {
                feed.innerHTML = "";
                historyCleared = true;
            }

            // History tag
            const tag = document.createElement("span");
            tag.className = "hkey";
            tag.textContent =
                e.key === " "
                    ? "Space"
                    : e.key.length > 8
                      ? e.code
                            .replace("Key", "")
                            .replace("Digit", "")
                            .replace("Numpad", "Num")
                      : e.key;
            tag.title = `${dur.toFixed(1)} ms`;
            feed.prepend(tag);
            while (feed.children.length > 36) feed.removeChild(feed.lastChild);

            // Stats
            totalKeys++;
            sCount.textContent = totalKeys;

            pressedCodes.add(e.code);
            sUnique.textContent = pressedCodes.size;

            if (dur < shortestPress) {
                shortestPress = dur;
                sShort.textContent = dur.toFixed(1);
                sScan.textContent = (1000 / dur).toFixed(0);
            }
        });

        btnReset.addEventListener("click", () => {
            shortestPress = Infinity;
            totalKeys = 0;
            historyCleared = false;
            pressedCodes.clear();
            sShort.textContent = "—";
            sScan.textContent = "—";
            sCount.textContent = "0";
            sUnique.textContent = "0";
            feed.innerHTML =
                '<span style="color:var(--muted);font-size:.78rem;">Keys will appear here…</span>';
            document
                .querySelectorAll(".k.pressed")
                .forEach((k) => k.classList.remove("pressed"));
            if (prompt) prompt.style.display = "";
        });
    </script>
