---
import Base from '@layouts/Base.astro';
---
<Base
  title="Page Not Found — Laptops Special"
  description="The page you are looking for does not exist. Return to Laptops Special to test your keyboard or mouse."
>
<style>
  .notfound {
    max-width: 600px; margin: 0 auto;
    padding: 6rem 1.5rem; text-align: center;
  }
  .notfound-code {
    font-family: var(--font-mono); font-size: 6rem; font-weight: 700;
    color: var(--border); line-height: 1; margin-bottom: 1rem;
  }
  .notfound h1 { font-size: 1.5rem; font-weight: 700; color: var(--text); margin-bottom: .75rem; }
  .notfound p { color: var(--text2); font-size: .9rem; margin-bottom: 2rem; line-height: 1.7; }
  .btn-home {
    display: inline-block; background: var(--accent); color: #0a0e1a;
    font-weight: 700; font-size: .875rem;
    padding: .7rem 1.5rem; border-radius: 8px;
    text-decoration: none; transition: opacity .2s;
  }
  .btn-home:hover { opacity: .85; }
</style>
<div class="notfound">
  <div class="notfound-code" aria-hidden="true">404</div>
  <h1>Page Not Found</h1>
  <p>The page you are looking for does not exist or has been moved. Head back to the homepage to test your keyboard or mouse.</p>
  <a href="/" class="btn-home" aria-label="Return to Laptops Special homepage">Go to Homepage</a>
</div>
</Base>
