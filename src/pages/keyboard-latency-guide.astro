            margin-bottom: 0.4rem;
        }
        .post-wrap strong {
            color: var(--text);
        }
        .post-wrap a {
            color: #00d4ff;
            text-decoration: none;
        }
        .post-wrap a:hover {
            text-decoration: underline;
        }

        .callout {
            background: rgba(0, 212, 255, 0.06);
            border: 1px solid rgba(0, 212, 255, 0.15);
            border-radius: 10px;
            padding: 1.1rem 1.25rem;
            margin: 1.5rem 0;
            font-size: 0.875rem;
            color: var(--text2);
