---
import Base from "@layouts/Base.astro";

const canonicalUrl = "https://laptopsspecial.com/keyboard-latency-guide";
const seoTitle =
    "Keyboard Latency Explained: What It Is and Why It Matters for Gaming";
const seoDescription =
    "Understand the difference between scan rate, polling rate, and response time — and how each affects your gaming performance.";

// 1. Article Schema
const articleSchema = {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: seoTitle,
    description: seoDescription,
    datePublished: "2026-06-15",
    dateModified: "2026-06-15",
    author: { "@type": "Organization", name: "Laptops Special" },
    publisher: {
        "@type": "Organization",
        name: "Laptops Special",
        url: "https://laptopsspecial.com",
        logo: {
            "@type": "ImageObject",
            url: "https://laptopsspecial.com/favicon.svg",
        },
    },
    url: canonicalUrl,
    mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
    keywords:
        "keyboard latency, keyboard polling rate, scan rate, gaming keyboard, input lag",
};

// 2. WebApplication Schema (keyboard tool reference)
const webAppSchema = {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "Laptops Special — Free Keyboard & Mouse Testing Tools",
    description:
        "Free online tools to test keyboard latency, mouse polling rate and gaming peripheral performance.",
    url: "https://laptopsspecial.com",
    applicationCategory: "UtilitiesApplication",
    operatingSystem: "Any",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    publisher: {
        "@type": "Organization",
        name: "Laptops Special",
        url: "https://laptopsspecial.com",
    },
};

// 3. FAQ Schema
const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
        {
            "@type": "Question",
            name: "What is average keyboard latency?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Most keyboards fall between 1ms and 15ms depending on switch type (mechanical vs membrane) and connection method.",
            },
        },
        {
            "@type": "Question",
            name: "Which keyboard has the lowest latency?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "The Logitech G915 TKL achieves as low as 1.3ms in wired mode, placing it among the fastest available keyboards today.",
            },
        },
        {
            "@type": "Question",
            name: "Does keyboard polling rate affect latency?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Yes. At 125Hz polling rate latency is around 8ms. At 1000Hz it drops to roughly 1ms. Higher polling rate equals lower latency.",
            },
        },
        {
            "@type": "Question",
            name: "How can I reduce keyboard latency on Windows?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Update keyboard drivers, disable Filter Keys in accessibility settings, use a wired USB 3.0 connection, and close background applications.",
            },
        },
    ],
};

// 4. BreadcrumbList Schema
const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: "https://laptopsspecial.com",
        },
        {
            "@type": "ListItem",
            position: 2,
            name: "Blog",
            item: "https://laptopsspecial.com/blog",
        },
        {
            "@type": "ListItem",
            position: 3,
            name: seoTitle,
            item: canonicalUrl,
        },
    ],
};
---

<Base
    title={`${seoTitle} | Laptops Special`}
    description={seoDescription}
    canonical={canonicalUrl}
    noWebAppSchema={true}
>
    <Fragment slot="head">
        <script
            type="application/ld+json"
            set:html={JSON.stringify(articleSchema)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(webAppSchema)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(faqSchema)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(breadcrumbSchema)}
        />
    </Fragment>
    <style>
        .post-hero {
            background: linear-gradient(
                135deg,
                rgba(0, 212, 255, 0.06),
                rgba(124, 58, 237, 0.06)
            );
            border-bottom: 1px solid #1e293b;
            padding: 3.5rem 1.5rem 2.5rem;
            text-align: center;
        }
        .post-meta-bar {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            flex-wrap: wrap;
            margin-bottom: 1.25rem;
        }
        .post-cat {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #00d4ff;
            background: rgba(0, 212, 255, 0.1);
            border: 1px solid rgba(0, 212, 255, 0.2);
            padding: 0.25rem 0.6rem;
            border-radius: 4px;
        }
        .post-date {
            font-size: 0.78rem;
            color: var(--muted);
        }
        .post-read {
            font-size: 0.78rem;
            color: var(--muted);
        }
        .dot {
            color: #334155;
        }
        .post-hero h1 {
            font-size: clamp(1.5rem, 3.5vw, 2.25rem);
            font-weight: 700;
            color: var(--text);
            line-height: 1.25;
            margin-bottom: 1rem;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
        }
        .post-hero .lead {
            color: var(--text2);
            font-size: 1rem;
            max-width: 580px;
            margin: 0 auto;
            line-height: 1.7;
        }

        .post-wrap {
            max-width: 760px;
            margin: 0 auto;
            padding: 3rem 1.5rem 4rem;
        }

        .post-wrap h2 {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--text);
            margin: 2.5rem 0 0.75rem;
            border-left: 3px solid #00d4ff;
            padding-left: 0.75rem;
        }
        .post-wrap h3 {
            font-size: 1rem;
            font-weight: 600;
            color: var(--text);
            margin: 1.5rem 0 0.5rem;
        }
        .post-wrap p {
            color: var(--text2);
            font-size: 0.9rem;
            line-height: 1.85;
            margin-bottom: 1rem;
        }
        .post-wrap ul,
        .post-wrap ol {
            color: var(--text2);
            font-size: 0.9rem;
            line-height: 1.85;
            padding-left: 1.5rem;
