---
export interface Props {
    slot: string;
    format?: string;
    layout?: string;
    label?: string;
}
const { slot, format = "auto", layout, label } = Astro.props;
---

<div class="ad-unit-wrap">
    {label && <span class="ad-unit-label">{label}</span>}
    <ins
        class="adsbygoogle"
        style="display:block"
        data-ad-client="ca-pub-9519394867922982"
        data-ad-slot={slot}
        data-ad-format={format}
        data-ad-layout={layout}
        data-full-width-responsive={format !== "autorelaxed" ? "true" : undefined}
    ></ins>
</div>

<script is:inline define:vars={{ id: crypto.randomUUID() }}>
    (function () {
        try {
            (window.adsbygoogle = window.adsbygoogle || []).push({});
        } catch (e) {}
    })();
</script>

<style>
    .ad-unit-wrap {
        margin: 1.5rem 0;
        text-align: center;
        min-height: 90px;
    }
    .ad-unit-label {
        display: block;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
        margin-bottom: 0.4rem;
    }
</style>
